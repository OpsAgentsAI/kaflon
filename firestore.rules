// IMPORTANT: opsagent-prod Firestore rules are SHARED across multiple apps.
// Do NOT deploy this file directly — merge these rules into the canonical shared
// firestore.rules in the msapps-lead-pipeline repo before deploying.
// See memory: reference_firestore_rules_absent_claim_errors_and_leads_rulestest_harness
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /subjects/{subjectId} {
      allow read: if request.auth != null;
      allow write: if false; // only via kaflonAgent Cloud Function
    }
    match /users/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
      match /kids/{kidId} {
        allow read, write: if request.auth != null && request.auth.uid == uid;
      }
    }
  }
}
